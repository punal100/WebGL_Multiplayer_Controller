{
  "name": "webgl-multiplayer-controller",
  "version": "1.0.0",
  "description": "Two-player WebGL game with virtual mobile controllers served over LAN",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "server": "node server/index.js",
    "serve": "node server/launch.js",
    "start": "npm run build && node server/launch.js",
    "pack": "node scripts/pack.js",
    "docker:build": "docker build -t webgl-mp-controller:latest .",
    "docker:run": "docker run -d --name webgl-mp -p 4567:4567 -e NODE_ENV=production --restart unless-stopped webgl-mp-controller:latest",
    "docker:up": "docker compose up -d --build"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "vite": "^7.3.6"
  }
}
